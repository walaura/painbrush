{
  "include": [
    "./api/*.ts",
    "./packer.ts"
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "skipLibCheck": true,
    "declaration": true
  }
}
